# Copy this file to .env and fill in your real values:
#   cp .env.example .env
#
# .env is gitignored — it will NEVER be pushed to GitHub.

# ── Vercel only (server-side, never in the mobile app) ──
# Set these in Vercel Dashboard → Settings → Environment Variables
GEMINI_API_KEY=your_gemini_api_key_here
MACROZONE_API_KEY=generate_with_openssl_rand_hex_32

# Supabase (server-side JWT verification for AI scans)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Upstash Redis (optional) — enables 20 scans/day/user rate limiting
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Expo app (local dev + EAS builds) ──
# EXPO_PUBLIC_* vars are baked into the APK at build time.
# Store production values in EAS → Environment Variables, not in Git.
EXPO_PUBLIC_ANALYZE_API_URL=https://macrozone-navy.vercel.app/api/analyze-meal

# Supabase (client-side auth)
# Use EXPO_PUBLIC_* in Expo — not NEXT_PUBLIC_* (Next.js only)
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key
# Alternative name (same value as ANON_KEY):
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Legacy fallback only when SUPABASE_URL is not set on the server.
# Do not ship this in production builds once auth is enabled.
EXPO_PUBLIC_MACROZONE_API_KEY=