{
  "expo": {
    "name": "nutriFlow",
    "slug": "macrozone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "macrozone",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/images/icon.png",
      "bundleIdentifier": "com.geraldy.macrozone",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.geraldy.macrozone"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#1a1a2e"
        }
      ],
      "expo-localization",
      [
        "expo-image-picker",
        {
          "photosPermission": "nutriFlow needs access to your photos to scan meals.",
          "cameraPermission": "nutriFlow needs access to your camera to scan meals."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "analyzeApiUrl": "",
      "eas": {
        "projectId": "b08f5b4a-5028-4051-baf5-bff0318dd539"
      }
    },
    "owner": "geraldy"
  }
}
